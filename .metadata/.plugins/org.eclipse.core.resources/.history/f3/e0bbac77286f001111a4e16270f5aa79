#include <stdio.h>
#include <stdint.h>
#include "stm32f4xx.h"
#include "uart.h"

#define GPIOAEN  (1u<<0)
#define GPIOA_5 (1U<<5)

#define LED_PIN  GPIOA_5



char key;

static void uart_callback(void) ;


int main(void)
{
	RCC -> AHB1ENR |= GPIOAEN;  // ENABLING THE CLOCK ACCESS
	GPIOA -> MODER |= (1U<<10); // SETTING PA5 TO OUTPUT PIN
	GPIOA -> MODER &=~ (1U<<11);


	uart2_rx_interrupt_init();

	while(1) {}

}

static void uart_callback(void)
{
	key = USART->DR;

	if(key == '1')
		{
			GPIOA -> ODR |= LED_PIN;
		}
		else {

			GPIOA -> ODR &=~ LED_PIN;
		}

}

void USART2_IRQHandler(void)
{
	if(USART2->SR & SR_RXNE) // checking if rxne is set
	{
		//DO SOMETHING
		uart_callback();

	}

}







